{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["owner", "service", "expiration", "profile", "image"],
  "additionalProperties": false,
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "service": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "httpService": {
      "type": "object",
      "required": ["enabled", "type", "port"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "expiration": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "profile": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "portRunId": {
      "type": "string",
      "minLength": 1
    },
    "sizeProfiles": {
      "type": "object"
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "roleBinding": {
      "type": "object",
      "required": ["subjectName", "subjectKind"],
      "properties": {
        "subjectName": {
          "type": "string",
          "minLength": 1
        },
        "subjectKind": {
          "type": "string",
          "enum": ["User", "Group", "ServiceAccount"]
        }
      }
    }
  }
}
